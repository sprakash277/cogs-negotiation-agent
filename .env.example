# COGS Negotiation Agent — deploy + runtime configuration.
#
# Copy to `.env` and edit, OR just `export` these before running bootstrap.py /
# the build scripts. EVERY knob has a default that reproduces the existing
# cogs-demo workspace, so with nothing set you target cogs-demo unchanged.
#
# ── Deploy-time knobs (read by deploy_config.py / bootstrap.py) ──────────────

# Databricks CLI profile the build scripts authenticate with.
# default: cogs-demo
# DATABRICKS_PROFILE=cogs-demo

# Unity Catalog catalog + schema the data lands in.
# defaults: kroger_demo / cogs
# COGS_CATALOG=kroger_demo
# COGS_SCHEMA=cogs

# SQL warehouse id used for statement execution + dashboard publish.
# default: "" => auto-pick a live serverless warehouse (cached into deploy_state.json).
# On cogs-demo with no value set, falls back to the known Serverless Starter id.
# WAREHOUSE_ID=a455a68035c1f578

# Vector Search endpoint name. bootstrap.py CREATES it if missing.
# default: kroger-recipe-search (reused on cogs-demo). Use a fresh name elsewhere.
# VS_ENDPOINT=kroger-recipe-search

# Embedding model serving endpoint backing the contract index.
# default: databricks-gte-large-en
# EMBED_MODEL=databricks-gte-large-en

# Genie/dashboard parent workspace path.
# default: "" => resolves to the current user's /Users/<me> via the SDK.
# BOOTSTRAP_PARENT_PATH=/Workspace/Users/you@example.com

# ── LLM provider (shared deploy + runtime) ───────────────────────────────────

# 'mosaic' (governed AI Gateway, default) or 'litellm' (OpenAI-compatible proxy).
# LLM_PROVIDER=mosaic
# LLM model / serving endpoint name.
# default: databricks-claude-sonnet-4-5
# LLM_MODEL=databricks-claude-sonnet-4-5

# ── Runtime app vars — PRODUCED by bootstrap.py / deploy_agent.py ─────────────
# These are written into deploy_state.json by the build steps; bootstrap.py
# prints the exact app.yaml block to paste. Listed here for reference only —
# you normally do NOT set them by hand.
#
# GENIE_SPACE_ID=      # captured by build_genie.py
# CONTRACT_INDEX=      # captured by build_knowledge.py (= <catalog>.<schema>.contract_chunks_index)
# DASHBOARD_ID=        # captured by build_dashboard.py
# LAKEBASE_INSTANCE=cogs-lakebase   # name of the attached Lakebase Postgres instance
